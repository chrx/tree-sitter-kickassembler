{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "kickassembler",
  "rules": {
    "program": {
      "type": "REPEAT",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "SYMBOL",
            "name": "statement"
          }
        ]
      }
    },
    "comment": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": "//"
          },
          {
            "type": "PATTERN",
            "value": ".*"
          }
        ]
      }
    },
    "string": {
      "type": "CHOICE",
      "members": [
        {
          "type": "PATTERN",
          "value": "\"[^\"]*\""
        },
        {
          "type": "PATTERN",
          "value": "'[^']*'"
        }
      ]
    },
    "block": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "{"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "statement"
          }
        },
        {
          "type": "STRING",
          "value": "}"
        }
      ]
    },
    "statement": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "block"
        },
        {
          "type": "SYMBOL",
          "name": "label"
        },
        {
          "type": "SYMBOL",
          "name": "inst"
        },
        {
          "type": "SYMBOL",
          "name": "command"
        }
      ]
    },
    "acc_register": {
      "type": "PATTERN",
      "value": "a",
      "flags": "i"
    },
    "x_register": {
      "type": "PATTERN",
      "value": "x",
      "flags": "i"
    },
    "y_register": {
      "type": "PATTERN",
      "value": "y",
      "flags": "i"
    },
    "inst": {
      "type": "SEQ",
      "members": [
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "opcode"
            },
            {
              "type": "SYMBOL",
              "name": "illegal"
            },
            {
              "type": "SYMBOL",
              "name": "control"
            },
            {
              "type": "SYMBOL",
              "name": "data"
            },
            {
              "type": "SYMBOL",
              "name": "math"
            },
            {
              "type": "SYMBOL",
              "name": "file"
            },
            {
              "type": "SYMBOL",
              "name": "threed"
            },
            {
              "type": "SYMBOL",
              "name": "storage"
            },
            {
              "type": "SYMBOL",
              "name": "object"
            },
            {
              "type": "SYMBOL",
              "name": "function"
            },
            {
              "type": "SYMBOL",
              "name": "preprocessor"
            }
          ]
        },
        {
          "type": "PATTERN",
          "value": ".*"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "STRING",
              "value": "\n"
            },
            {
              "type": "STRING",
              "value": ";"
            }
          ]
        }
      ]
    },
    "label": {
      "type": "PATTERN",
      "value": "[A-Za-z_@!][A-Za-z0-9_]*:"
    },
    "symbol": {
      "type": "PATTERN",
      "value": "[A-Za-z_@!][A-Za-z0-9_\\.]*"
    },
    "command": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "byte"
        },
        {
          "type": "SYMBOL",
          "name": "word"
        },
        {
          "type": "SYMBOL",
          "name": "text"
        },
        {
          "type": "SYMBOL",
          "name": "import"
        },
        {
          "type": "SYMBOL",
          "name": "memblock"
        },
        {
          "type": "SYMBOL",
          "name": "namespace"
        },
        {
          "type": "SYMBOL",
          "name": "macro"
        }
      ]
    },
    "byte": {
      "type": "SEQ",
      "members": [
        {
          "type": "PATTERN",
          "value": "\\.byte"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "operand_8"
            },
            {
              "type": "SEQ",
              "members": [
                {
                  "type": "REPEAT",
                  "content": {
                    "type": "SEQ",
                    "members": [
                      {
                        "type": "SYMBOL",
                        "name": "operand_8"
                      },
                      {
                        "type": "STRING",
                        "value": ","
                      }
                    ]
                  }
                },
                {
                  "type": "SYMBOL",
                  "name": "operand_8"
                }
              ]
            }
          ]
        }
      ]
    },
    "word": {
      "type": "SEQ",
      "members": [
        {
          "type": "PATTERN",
          "value": "\\.word",
          "flags": "i"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "operand_16"
            },
            {
              "type": "REPEAT",
              "content": {
                "type": "SEQ",
                "members": [
                  {
                    "type": "SYMBOL",
                    "name": "operand_16"
                  },
                  {
                    "type": "STRING",
                    "value": ","
                  }
                ]
              }
            }
          ]
        }
      ]
    },
    "text": {
      "type": "SEQ",
      "members": [
        {
          "type": "PATTERN",
          "value": "\\.text",
          "flags": "i"
        },
        {
          "type": "SYMBOL",
          "name": "string"
        }
      ]
    },
    "import": {
      "type": "SEQ",
      "members": [
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "PATTERN",
              "value": "#import"
            },
            {
              "type": "PATTERN",
              "value": "#importonce"
            }
          ]
        },
        {
          "type": "SYMBOL",
          "name": "string"
        }
      ]
    },
    "memblock": {
      "type": "SEQ",
      "members": [
        {
          "type": "PATTERN",
          "value": "\\.memblock"
        },
        {
          "type": "SYMBOL",
          "name": "string"
        }
      ]
    },
    "namespace": {
      "type": "SEQ",
      "members": [
        {
          "type": "PATTERN",
          "value": "\\.namespace"
        },
        {
          "type": "SYMBOL",
          "name": "symbol"
        },
        {
          "type": "SYMBOL",
          "name": "block"
        }
      ]
    },
    "macro_name": {
      "type": "PATTERN",
      "value": "[A-Za-z_@!][A-Za-z0-9_\\.]*\\(\\)"
    },
    "macro": {
      "type": "SEQ",
      "members": [
        {
          "type": "PATTERN",
          "value": "\\.macro"
        },
        {
          "type": "SYMBOL",
          "name": "macro_name"
        },
        {
          "type": "SYMBOL",
          "name": "byte"
        }
      ]
    },
    "operand_8": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "bin_8"
        },
        {
          "type": "SYMBOL",
          "name": "dec_8"
        },
        {
          "type": "SYMBOL",
          "name": "hex_8"
        },
        {
          "type": "SYMBOL",
          "name": "colour"
        },
        {
          "type": "SYMBOL",
          "name": "opcode_imm"
        },
        {
          "type": "SYMBOL",
          "name": "file_type"
        }
      ]
    },
    "bin_8": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "%"
        },
        {
          "type": "PATTERN",
          "value": "0*[01]{1,8}"
        }
      ]
    },
    "dec_8": {
      "type": "PATTERN",
      "value": "0*(25[0-5]|2[0-4][0-9]|[01]?[0-9]{1,2})"
    },
    "hex_8": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SEQ",
          "members": [
            {
              "type": "CHOICE",
              "members": [
                {
                  "type": "STRING",
                  "value": "$"
                },
                {
                  "type": "STRING",
                  "value": "h"
                }
              ]
            },
            {
              "type": "PATTERN",
              "value": "0*[0-9a-fA-F]{1,2}"
            }
          ]
        },
        {
          "type": "PATTERN",
          "value": "0*[0-9a-fA-F]{1,2}h"
        }
      ]
    },
    "colour": {
      "type": "PATTERN",
      "value": "BLACK|WHITE|RED|CYAN|PURPLE|GREEN|BLUE|YELLOW|ORANGE|BROWN|LIGHT_RED|DARK_GRAY|GRAY|DARK_GREY|GREY|LIGHT_GREEN|LIGHT_BLUE|LIGHT_GRAY|LIGHT_GREY"
    },
    "opcode_imm": {
      "type": "PATTERN",
      "value": "LDA_IMM|LDA_ZP|LDA_ZPX|LDX_ZPY|LDA_IZPX|LDA_IZPY|LDA_ABS|LDA_ABSX|LDA_ABSY|JMP_IND|BNE_REL|RTS"
    },
    "file_type": {
      "type": "PATTERN",
      "value": "BF_C64FILE|BF_BITMAP_SINGLECOLOR|BF_KOALA|BF_FLI"
    },
    "operand_16": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "bin_16"
        },
        {
          "type": "SYMBOL",
          "name": "dec_16"
        },
        {
          "type": "SYMBOL",
          "name": "hex_16"
        },
        {
          "type": "SYMBOL",
          "name": "colour"
        },
        {
          "type": "SYMBOL",
          "name": "opcode_imm"
        },
        {
          "type": "SYMBOL",
          "name": "file_type"
        }
      ]
    },
    "bin_16": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "%"
        },
        {
          "type": "PATTERN",
          "value": "0*[01]{9,16}"
        }
      ]
    },
    "dec_16": {
      "type": "PATTERN",
      "value": "0*(6553[0-5]|655[0-2]\\d|65[0-4]\\d{2}|6[0-4]\\d{3}|[1-5]?\\d{1,4})"
    },
    "hex_16": {
      "type": "SEQ",
      "members": [
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "STRING",
              "value": "$"
            },
            {
              "type": "STRING",
              "value": "h"
            }
          ]
        },
        {
          "type": "PATTERN",
          "value": "0*[0-9a-fA-F]{3,4}"
        }
      ]
    },
    "imm_prefix": {
      "type": "STRING",
      "value": "#"
    },
    "opcode": {
      "type": "PATTERN",
      "value": "adc|and|asl|bit|clc|cld|cli|clv|cmp|cpx|cpy|dec|dex|dey|eor|inc|inx|iny|lda|ldx|ldy|lsr|nop|ora|pha|php|pla|plp|rol|ror|sbc|sec|sed|sei|sta|stx|sty|tax|txa|tay|tya|tsx|txs",
      "flags": "i"
    },
    "illegal": {
      "type": "PATTERN",
      "value": "aac|aax|alr|anc|ane|arr|aso|asr|atx|axa|axs|dcm|dcp|dop|hlt|ins|isb|isc|jam|kil|lae|lar|las|lax|lse|lxa|oal|rla|rra|sax|sbx|skb|sha|shs|say|shx|shy|slo|skw|sre|sxa|sya|tas|top|xaa|xas",
      "flags": "i"
    },
    "control": {
      "type": "PATTERN",
      "value": "bcc|bcs|beq|bmi|bne|bpl|brk|bvc|bvs|jmp|jsr|rti|rts",
      "flags": "i"
    },
    "data": {
      "type": "PATTERN",
      "value": "\\.(word|byte|text|dword)",
      "flags": "i"
    },
    "math": {
      "type": "PATTERN",
      "value": "abs|acos|asin|atan|atan2|cbrt|ceil|cos|cosh|exp|expm1|floor|hypot|IEEEremainder|log|log10|log1p|max|min|pow|mod|random|round|signum|sin|sinh|sqrt|tan|tanh|toDegrees|toRadians"
    },
    "file": {
      "type": "PATTERN",
      "value": "LoadBinary|LoadPicture|LoadSid|createFile"
    },
    "threed": {
      "type": "PATTERN",
      "value": "Matrix|RotationMatrix|ScaleMatrix|MoveMatrix|PerspectiveMatrix|Vector"
    },
    "storage": {
      "type": "PATTERN",
      "value": "\\.(var|label|const)",
      "flags": "i"
    },
    "object": {
      "type": "PATTERN",
      "value": "\\.(struct|enum)",
      "flags": "i"
    },
    "function": {
      "type": "PATTERN",
      "value": "\\.(eval|fill|print|printnow|align|assert|asserterror|error)"
    },
    "preprocessor": {
      "type": "PATTERN",
      "value": "\\.(pc|pseudopc|return|eval)",
      "flags": "i"
    }
  },
  "extras": [
    {
      "type": "SYMBOL",
      "name": "comment"
    },
    {
      "type": "PATTERN",
      "value": "\\s"
    }
  ],
  "conflicts": [],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}